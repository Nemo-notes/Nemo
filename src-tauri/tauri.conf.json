{
  "productName": "Nabu",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../crates/nabu-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cargo run -p nabu-ui -- dev",
    "beforeBuildCommand": "cargo build -p nabu-ui --release"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nabu",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "wizard",
        "title": "Nabu Setup",
        "width": 440,
        "height": 620,
        "resizable": false,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "dictation-pill",
        "title": "Dictation",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "width": 200,
        "height": 50
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 750,
        "height": 520,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost;"
    }
  },
  "bundle": {
    "identifier": "md.nabu.app",
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}

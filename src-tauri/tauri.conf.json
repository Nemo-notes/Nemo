{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nabu",
  "version": "0.1.0",
  "identifier": "md.nabu.app",
  "build": {
    "beforeDevCommand": "trunk serve",
    "beforeBuildCommand": "trunk build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nabu Setup",
        "label": "wizard",
        "width": 440,
        "height": 620,
        "resizable": false,
        "visible": true
      },
      {
        "title": "Nabu",
        "label": "main",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "visible": false
      },
      {
        "title": "Nabu Settings",
        "label": "settings",
        "width": 750,
        "height": 520,
        "resizable": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}

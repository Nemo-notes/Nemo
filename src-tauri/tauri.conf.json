{
  
  "productName": "Nabu",
  "version": "1.0.0",
  "identifier": "com.nabu.app",
  "build": {
    "frontendDist": "../crates/nabu-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cargo run -p nabu-ui -- dev",
    "beforeBuildCommand": "cargo build -p nabu-ui --release"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nabu",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "dictation-pill",
        "title": "Dictation",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "width": 200,
        "height": 50
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Nabu Labs",
    "copyright": "Copyright © 2024 Nabu Labs. All rights reserved.",
    "category": "Productivity",
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}

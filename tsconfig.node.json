{
  "include": ["src/shared/**/*"],
  "compilerOptions": {
    "composite": true,
    "target": "es2015",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"],
      "@renderer-shared/*": ["./src/renderer/src/shared/*"]
    }
  }
}

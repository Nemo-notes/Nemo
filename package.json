{
  "name": "nabu",
  "version": "1.0.0",
  "description": "Markdown-native knowledge base for developers — on disk, plain .md, zero lock-in",
  "author": "Nabu Labs <hello@nabu.app>",
  "homepage": "https://nabu.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nabu/Nabu.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache . --quiet --max-warnings=0",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "copy-models": "node scripts/copy-models.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --config eslint.config.mjs --quiet --max-warnings=0"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.1",
    "@headlessui/react": "^2.2.10",
    "@tauri-apps/api": "^2.11.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-codemirror": "^4.25.11",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "d3-force": "^3.0.0",
    "katex": "^0.17.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^6.1.200",
    "react-syntax-highlighter": "^16.1.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vectra": "^0.15.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/cytoscape": "^3.31.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "canvas": "^3.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}

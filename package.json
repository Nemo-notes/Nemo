{
  "name": "nabu",
  "version": "1.0.0",
  "description": "Markdown-native knowledge base for developers — on disk, plain .md, zero lock-in",
  "main": "./out/main/index.js",
  "author": "Nabu Labs <hello@nabu.app>",
  "homepage": "https://nabu.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nabu/Nabu.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "copy-models": "node scripts/copy-models.js",
    "build:mac": "npm run copy-models && npm run typecheck && electron-vite build && electron-builder --mac --publish never",
    "build:mac:dev": "npm run typecheck && electron-vite build && electron-builder --mac --dir --config.extraMetadata.environment=development",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:arch": "npm run validate:circular",
    "validate:circular": "npx madge --circular src/"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@headlessui/react": "^2.2.10",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-codemirror": "^4.25.11",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "d3-force": "^3.0.0",
    "katex": "^0.18.1",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^6.1.200",
    "react-syntax-highlighter": "^16.1.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vectra": "^0.15.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "canvas": "^3.2.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.8.0",
    "madge": "^6.0.0",
    "prettier": "^3.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "electron@39.8.10": true
  }
}
